# Auto detect text files and perform LF normalization
* text=auto

# Enforce Python as the primary repository language on GitHub
# Mark frontend files and lockfiles as vendored/generated so they are excluded from language stats
frontend/** linguist-vendored=true
package.json linguist-generated=true
package-lock.json linguist-generated=true

# Explicitly ensure Python files are counted
backend/**.py linguist-detectable=true
